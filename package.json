{
  "name": "mtg-games",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "dotenv -e .dev.env -- react-router dev",
    "dev:test": "dotenv -e .test.env -- react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "format": "prettier --write .",
    "format-check": "prettier --check .",
    "lint": "eslint .",
    "prisma-generate": "dotenv -e .dev.env -- prisma generate",
    "test": "npm exec -- prisma migrate reset --force && npm exec -- playwright test",
    "test:dev": "dotenv -e .test.env -- npm run test"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@emotion/cache": "latest",
    "@emotion/react": "latest",
    "@emotion/server": "latest",
    "@emotion/styled": "latest",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/x-date-pickers": "^9.0.0",
    "@mui/x-charts": "^9.0.0",
    "@prisma/adapter-better-sqlite3": "^7.2.0",
    "@prisma/client": "^7.0.0",
    "@react-router/node": "^7.14.2",
    "@react-router/serve": "^7.14.2",
    "date-fns": "^4.1.0",
    "isbot": "latest",
    "prettier": "^3.6.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.2",
    "simple-statistics": "^7.8.8",
    "vite-plugin-svgr": "^5.0.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@playwright/test": "^1.57.0",
    "@react-router/dev": "latest",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.0",
    "prisma": "^7.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.35.1",
    "vite": "latest"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-musl": "4.61.0"
  }
}
